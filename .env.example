# Copy to .env and fill in your credentials.

# IBM Quantum (Open Plan or paid).
# Get one at: https://quantum.cloud.ibm.com/
IBM_QUANTUM_TOKEN=

# Azure Quantum Workspace (Quantinuum H2-1, H2-1E, etc).
# After creating the workspace in Azure Portal, copy these from
# Workspace > Overview > "Properties":
#   AZURE_QUANTUM_RESOURCE_ID example:
#     /subscriptions/00000000-0000-0000-0000-000000000000/
#      resourceGroups/myrg/providers/Microsoft.Quantum/Workspaces/myws
#   AZURE_QUANTUM_LOCATION example: japaneast, eastus, westeurope
AZURE_QUANTUM_RESOURCE_ID=
AZURE_QUANTUM_LOCATION=

# Auth for Azure uses DefaultAzureCredential. The recommended setup is:
#   1. Install Azure CLI:  https://learn.microsoft.com/cli/azure/install-azure-cli
#   2. Run `az login` once in this shell — it caches the token.
# Or set service-principal env vars (AZURE_TENANT_ID, AZURE_CLIENT_ID,
# AZURE_CLIENT_SECRET) for automation.
